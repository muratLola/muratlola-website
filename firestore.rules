rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function userDoc(uid) { return get(/databases/$(database)/documents/users/$(uid)); }
    function hasUserDoc(uid) { return exists(/databases/$(database)/documents/users/$(uid)); }
    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        (hasUserDoc(request.auth.uid) && userDoc(request.auth.uid).data.role == 'admin')
      );
    }
    function userActive() {
      return signedIn() && hasUserDoc(request.auth.uid) && userDoc(request.auth.uid).data.status == 'active';
    }
    function roleSelectable(role) {
      return role in ['designer', 'club'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (
        isOwner(userId) &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.status == resource.data.status &&
        (
          request.resource.data.role == resource.data.role ||
          (!(resource.data.role in ['designer','club','admin']) && roleSelectable(request.resource.data.role))
        )
      );
      allow delete: if isAdmin();
    }

    match /designs/{designId} {
      allow read: if (resource.data.status == 'approved' && resource.data.visibility == 'public')
                  || isAdmin()
                  || (signedIn() && resource.data.designerId == request.auth.uid);

      allow create: if signedIn() && userActive() && hasUserDoc(request.auth.uid) &&
                    userDoc(request.auth.uid).data.role == 'designer' &&
                    request.resource.data.designerId == request.auth.uid &&
                    request.resource.data.status == 'pending';

      allow update: if isAdmin() || (
        signedIn() && userActive() && resource.data.designerId == request.auth.uid &&
        request.resource.data.designerId == resource.data.designerId &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.visibility == resource.data.visibility &&
        request.resource.data.featured == resource.data.featured &&
        request.resource.data.editorPick == resource.data.editorPick &&
        request.resource.data.likes == resource.data.likes &&
        request.resource.data.views == resource.data.views &&
        request.resource.data.sales == resource.data.sales &&
        request.resource.data.trendScore == resource.data.trendScore
      );

      allow delete: if isAdmin();
    }

    match /competitions/{competitionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /competitions/{competitionId}/submissions/{submissionId} {
      allow read: if true;
      allow create: if signedIn() && userActive() && hasUserDoc(request.auth.uid) && userDoc(request.auth.uid).data.role == 'designer';
      allow update, delete: if isAdmin() || (signedIn() && resource.data.designerId == request.auth.uid);
    }

    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /site_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/favorites/{designId} {
      allow read, create, delete: if isOwner(userId);
      allow update: if false;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if isAdmin() || (signedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.designerId == request.auth.uid
      ));
      allow create, update, delete: if false;
    }

    match /payout_requests/{payoutId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;
    }
  }
}
