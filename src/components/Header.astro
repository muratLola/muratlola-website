---
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const links = [
  { href: '/projeler', label: 'Projeler' },
  { href: '/formalar', label: 'Formalar' },
  { href: '/hakkimda', label: 'Hakkımda' },
  { href: '/iletisim', label: 'İletişim' },
];
const active = (h) => path === h || path.startsWith(h + '/');
---
<header class="hdr" id="hdr">
  <a class="brand" href="/"><span class="brand__name">muratLola</span></a>

  <nav class="nav" id="nav">
    {links.map(l => (
      <a href={l.href} aria-current={active(l.href) ? 'page' : undefined}>{l.label}</a>
    ))}
    <a href="/iletisim" class="nav__cta">Birlikte Çalışalım</a>
  </nav>

  <button class="theme" id="theme" aria-label="Aydınlık / karanlık mod" title="Aydınlık / karanlık mod">
    <svg class="t-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>
    </svg>
    <svg class="t-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4.2"/>
      <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/>
    </svg>
  </button>
  <button class="burger" id="burger" aria-label="Menü" aria-expanded="false"><i></i><i></i></button>
</header>
