---
import Base from '../layouts/Base.astro';
---
<Base title="Proje — muratLola">
  <section class="section" style="padding-top:12rem;">
    <a class="btn" href="/projeler" style="margin-bottom:3rem;"><i>←</i><span>Projeler</span></a>
    <div id="detail">
      <p class="label">Yükleniyor…</p>
    </div>
  </section>
</Base>

<script>
  import { getProject } from '../lib/store.js';
  import { revealAll, guardImages } from '../scripts/dom.js';

  const esc = (s) => String(s ?? '').replace(/[&<>"']/g, c => (
    { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c]
  ));

  const slug = new URLSearchParams(location.search).get('p');
  const root = document.getElementById('detail');

  if (!slug) {
    root.innerHTML = `<h1 class="h2">Proje belirtilmedi</h1>`;
  } else {
    getProject(slug).then(p => {
      if (!p) {
        root.innerHTML = `<h1 class="h2">Bulunamadı</h1>
          <p style="color:var(--dim);margin-top:1.2rem;">Bu proje kaldırılmış olabilir.</p>`;
        return;
      }
      document.title = `${p.title} — muratLola`;
      const gallery = (p.images ?? []).filter(Boolean);

      root.innerHTML = `
        <div class="eyebrow"><i></i><span>${esc(p.category)} · ${esc(p.year)}</span></div>
        <h1 class="h2">${esc(p.title)}</h1>
        ${p.award ? `<p class="kit__award" style="margin-top:1rem;">${esc(p.award)}</p>` : ''}
        ${p.summary ? `<p class="statement" style="font-size:clamp(1.4rem,2.8vw,2.4rem);margin-top:2rem;">${esc(p.summary)}</p>` : ''}
        ${p.cover ? `<div class="about__frame" style="aspect-ratio:16/9;margin-top:4rem;" data-reveal>
            <img src="${esc(p.cover)}" alt="${esc(p.title)}" style="height:100%;">
          </div>` : ''}
        ${p.body ? `<p style="color:var(--dim);max-width:60ch;margin-top:3rem;white-space:pre-line;">${esc(p.body)}</p>` : ''}
        ${gallery.length ? `<div class="kit-grid" style="margin-top:5rem;">
            ${gallery.map(src => `<div class="kit"><div class="kit__media" data-reveal>
              <img src="${esc(src)}" alt="" loading="lazy">
            </div></div>`).join('')}
          </div>` : ''}
      `;
      revealAll(root);
      guardImages(root);
    });
  }
</script>
