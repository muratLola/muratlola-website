---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'muratLola — Görsel İletişim Tasarımcısı & Art Director',
  description = 'Murat Ogur (muratLola) — Art Director, Fora Creative Studio kurucu ortağı. Spor kulüpleri ve markalar için kurumsal kimlik, forma tasarımı ve görsel strateji.',
  veil = false,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
  <meta name="theme-color" content="#FBFAF8" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL('/img/murat-ogur.jpg', Astro.site)} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Tema, sayfa boyanmadan ÖNCE uygulanmalı. Bundle'a alınırsa geç
       çalışır ve karanlık modda ilk kare beyaz parlar (FOUC).
       is:inline = Astro dokunmasın, olduğu gibi head'e gömülsün. -->
  <script is:inline>
    (function () {
      try {
        var kayit = localStorage.getItem('ml-theme');
        var koyu = kayit ? kayit === 'dark'
                         : matchMedia('(prefers-color-scheme: dark)').matches;
        if (koyu) document.documentElement.setAttribute('data-theme', 'dark');
      } catch (e) { /* localStorage kapalıysa aydınlık kalsın */ }
    })();
  </script>
</head>
<body>

  {veil && (
    <div class="veil" id="veil">
      <div class="veil__word"><span>muratLola</span></div>
      <div class="veil__line"><i></i></div>
    </div>
  )}

  <Header />
  <main><slot /></main>
  <Footer />

  <script>
    import '../scripts/app.js';
  </script>
</body>
</html>
